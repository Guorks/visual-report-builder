{
  "name": "visual-report-builder",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Hand-drawn HTML report builder — typed IR, deterministic renderer, eval harness.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
